PORT=3000
# Comma-separated list of allowed browser origins (e.g. http://localhost:5173)
CORS_ORIGIN_WHITELIST=http://localhost:3000,http://localhost:5173
# PostgreSQL connection URL (TypeORM)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poc_chat
# Auto-create/update tables from entities (disable in production; use migrations instead)
DB_SYNCHRONIZE=true
DB_LOGGING=false
